# OSMRoad Environment Variables

# ============================================
# FOR LOCAL DEVELOPMENT (vercel dev)
# These are used by the Edge Function (server-side only)
# ============================================

# Google Vertex AI Configuration
# Service Account JSON (paste full JSON content)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Cloud Project ID
# Preferred: GOOGLE_CLOUD_PROJECT
# Legacy alias still supported: GOOGLE_PROJECT_ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI Location
# Preferred: VERTEX_AI_LOCATION
# Legacy alias still supported: GOOGLE_LOCATION
VERTEX_AI_LOCATION=us-central1

# Vertex AI Model
VERTEX_AI_MODEL=gemini-2.5-flash

# ============================================
# NOTES FOR VERCEL DEPLOYMENT:
# ============================================
# Add these environment variables in Vercel Dashboard:
# Project Settings → Environment Variables
#
# GOOGLE_SERVICE_ACCOUNT_JSON: <paste full JSON>
# GOOGLE_CLOUD_PROJECT: your-project-id
# VERTEX_AI_LOCATION: us-central1
# VERTEX_AI_MODEL: gemini-2.5-flash
#
# NO CLIENT-SIDE ENV VARIABLES NEEDED!
# All AI processing happens in Edge Function
